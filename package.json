{
  "name": "exem-sencha-inspector",
  "description": "Chrome DevTools extension scaffold for Sencha Inspector.",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "check": "pnpm lint && pnpm typecheck",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "@biomejs/biome": "^2.4.6",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}
